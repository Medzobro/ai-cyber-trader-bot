# 🤖 AI Cyber-Trader Bot - Environment Variables
# ================================================
# Copy this file to .env and fill in your values

# ─── Telegram ───────────────────────────────────
# Get your token from @BotFather
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Admin user IDs (comma-separated)
ADMIN_IDS=

# ─── AI Providers (Server defaults - users can bring their own keys) ──
# Users can set their own API keys per provider via the bot
# These are optional server-level fallbacks

# DeepSeek (default provider)
# Get key from: https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI (optional)
OPENAI_API_KEY=

# Google Gemini (optional)
GEMINI_API_KEY=

# Anthropic Claude (optional)
CLAUDE_API_KEY=

# ─── Encryption ─────────────────────────────────
# Secret for AES-256 encryption of user API keys
# CHANGE THIS in production! Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_SECRET=change-me-to-a-random-64-char-string

# ─── MetaTrader 5 ───────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=ICMarkets-Demo

# ─── GitHub ────────────────────────────────────
# GitHub Personal Access Token (classic)
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=
GITHUB_BASE_URL=https://api.github.com
GITHUB_USERNAME=

# ─── Database ───────────────────────────────────
DB_PATH=data/trader_bot.db
