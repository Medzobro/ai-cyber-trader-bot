# 🤖 AI Cyber-Trader Bot - Environment Variables
# ================================================
# انسخ هذا الملف إلى `.env` واملأ القيم الخاصة بك

# ─── Telegram ───────────────────────────────────
# احصل على التوكن من @BotFather
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# معرفات المدراء (مفصولة بفاصلة)
ADMIN_IDS=

# ─── DeepSeek AI ────────────────────────────────
# احصل على API Key من: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ─── MetaTrader 5 ───────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=ICMarkets-Demo

# ─── Database ───────────────────────────────────
DB_PATH=data/trader_bot.db
